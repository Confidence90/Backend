# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-baaralink-change-this-in-production-2025
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ─── Base de données PostgreSQL ───────────────────────────────────────────────
DB_NAME=baaralink_db
DB_USER=baaralink_user
DB_PASSWORD=baaralink_password_2025
DB_HOST=db
DB_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── CORS (Frontend / Flutter web) ────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# ─── SMS / OTP ────────────────────────────────────────────────────────────────
# Provider: 'twilio' ou 'orange_mali'
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1234567890

# ─── Mobile Money ─────────────────────────────────────────────────────────────
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/ml/v1
ORANGE_MONEY_API_KEY=your-orange-money-api-key-here

WAVE_API_URL=https://api.wave.com/v1
WAVE_API_KEY=your-wave-api-key-here

# ─── Stockage fichiers (optionnel — désactivé par défaut) ─────────────────────
USE_S3=False
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_BUCKET_NAME=baaralink-media
# AWS_REGION=us-east-1

# ─── Firebase (notifications push) ───────────────────────────────────────────
# FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
